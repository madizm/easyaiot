# 从 VIDEO 项目对齐的 Nacos 配置
# 仓库内已提供 .env（本地）与 .env.docker（容器网络）；也可 cp env.example .env 自行生成
# Docker 配置：python app.py --env=docker

FLASK_RUN_PORT=8000

# 单次 HTTP 请求体上限（MB），文件夹上传由前端分批，单批仍受此限制
# AUTO_LABELING_MAX_UPLOAD_MB=5120

# Nacos 服务器（宿主机中间件用 localhost；Docker Compose 同网络可用 Nacos:8848）
NACOS_SERVER=localhost:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=basiclab@iot78475418754
SERVICE_NAME=auto-labeling-server
# POD_IP=

# 云平台数据集服务（iot-dataset，经网关 /admin-api/dataset/**）
# Docker host 网络模式请用 127.0.0.1，Compose bridge 网络才用 iot-gateway
DATASET_API_BASE=http://127.0.0.1:48080/admin-api
# DATASET_API_TOKEN=Bearer ...
# DATASET_API_VERIFY_SSL=true

# MinIO（下载/上传数据集压缩包与图片，与 VIDEO/.env.docker 对齐）
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minio_root
# MINIO_SECRET_KEY=minio_123456
# MINIO_SECURE=false
# MINIO_BUCKET=dataset
# MINIO_DATASETS_BUCKET=datasets
